{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "preserve",
    "allowImportingTsExtensions": false
  },
  "include": ["vite.config.js", "*.config.js", "*.config.ts"]
}